# ─────────────────────────────────────────────────────────────────────────────
# Mercury Retrograde — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env
#
# NEVER commit .env to git — it is listed in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Required in production ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Required: set ADMIN_API_KEY to enable API authentication
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=

# ── LLM API keys (at least one required for LLM-based evaluation) ─────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
LAKERA_GUARD_API_KEY=
LAKERA_GUARD_URL=https://api.lakera.ai/v2/guard
LAKERA_GUARD_PROJECT_ID=

# ── Ollama (local models — no API key needed) ─────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── vLLM (local OpenAI-compatible high-throughput server — no API key needed) ──
# Run with: vllm serve <model_id> --port 8000
VLLM_BASE_URL=http://localhost:8000

# ── Rebuff (optional runtime prompt-injection detection) ───────────────────────
# REBUFF_ENABLED=false
# REBUFF_API_TOKEN=
# REBUFF_API_URL=https://playground.rebuff.ai
# REBUFF_MAX_HEURISTIC_SCORE=0.75
# REBUFF_MAX_VECTOR_SCORE=0.90
# REBUFF_MAX_MODEL_SCORE=0.90
# REBUFF_CHECK_HEURISTIC=true
# REBUFF_CHECK_VECTOR=true
# REBUFF_CHECK_LLM=true

# ── Llama Guard (runtime safety classifier) ───────────────────────────────────
# Requires a Llama Guard model to be installed in Ollama (ollama pull llama-guard3:8b)
# Set LLAMA_GUARD_ENABLED=true to activate automatic safety classification on telemetry ingestion
# LLAMA_GUARD_ENABLED=false
# LLAMA_GUARD_MODEL_ID=llama-guard3:8b
# LLAMA_GUARD_TIMEOUT_SECONDS=10

# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite (no config needed)
# For PostgreSQL: postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./data/llm_eval.db

# ── Redis (optional — enables distributed job queue) ─────────────────────────
REDIS_URL=

# ── Dev mode ─────────────────────────────────────────────────────────────────
# Set to true to suppress SECRET_KEY warning in local development
# NEVER set this in production
MERCURY_DEV_MODE=false

# ── Timeouts (seconds) — override defaults if needed ─────────────────────────
# LLM_TIMEOUT_SECONDS=60
# HTTP_TIMEOUT_SECONDS=5
# REPORT_TIMEOUT_SECONDS=120
# LAKERA_GUARD_TIMEOUT_SECONDS=5
# LAKERA_GUARD_FAIL_CLOSED=false

# ── Eval defaults ─────────────────────────────────────────────────────────────
# DEFAULT_MAX_SAMPLES=50
# MAX_CONCURRENT_RUNS=3
